# ─────────────────────────────────────────────────
# Resume Maker — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Supabase ────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — used server-side only (Stripe webhook).
# ⚠️  Never expose this on the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Google OAuth ────────────────────────────────
# These are configured in the **Supabase Dashboard** under
# Authentication → Providers → Google.
# You do NOT need them in this .env file.
#
# 1. Create an OAuth 2.0 Client in Google Cloud Console
#    → https://console.cloud.google.com/apis/credentials
# 2. Paste the Client ID & Secret into the Supabase provider settings
# 3. Add redirect URLs in Supabase:
#    - http://localhost:3000/auth/callback  (local)
#    - https://your-domain.com/auth/callback (production)

# ── Stripe ──────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret
# Local dev:  run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
#             and copy the whsec_... value it prints.
# Production: create a webhook at https://dashboard.stripe.com/webhooks
#             pointing to https://your-domain.com/api/stripe/webhook
#             and subscribe to:
#               - checkout.session.completed
#               - customer.subscription.updated
#               - customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# The Price ID of your Pro subscription product
# Create a subscription product at: https://dashboard.stripe.com/products
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...
